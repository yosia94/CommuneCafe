<!DOCTYPE html>
<html>
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <link rel="icon" type="image/x-icon" href="/communefavicon.ico">
  <title>Admin Dashboard - Commune Cafe</title>
  <link rel="stylesheet" href="/styles.css">
</head>
<body>
  <div class="form-box">
    <h2>Admin Dashboard</h2>

    <p><strong>Welcome, <%= admin.username %></strong></p>
    <p>Role: <%= admin.role %></p>

    <hr>

    <ul>
      <li><a href="/admin/event-settings">Manage Event Settings</a></li>
      <li><a href="/admin/welcome-message">Manage Welcome Message</a></li>
      <li><a href="/admin/email-templates">Manage Email Templates</a></li>

      <% if (admin.role === 'superadmin') { %>
        <li><a href="/admin/manage-admins">Manage Admins</a></li>
      <% } %>

    </ul>

    <a href="/" class="back-button">⬅ Back to Main Page</a>
    <a href="/admin/logout" class="back-button">Logout</a>
  </div>
</body>
</html>