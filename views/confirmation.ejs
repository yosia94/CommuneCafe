<!DOCTYPE html>
<html>
<head>
  <title>Registration Success</title>
  <style>
    body { font-family: Arial, sans-serif; background: #f8f9fa; }
    .success-box {
      background: #d4edda;
      color: #155724;
      padding: 20px;
      border-radius: 5px;
      margin: 50px auto;
      width: 400px;
      text-align: center;
      box-shadow: 0 2px 5px rgba(0,0,0,0.1);
    }
  </style>
</head>
<body>
  <div class="success-box">
    ✅ Thanks for registering, <%= name %>! <br><br>
    Please check your email for event details.<br>
    If you don't find the email in your inbox, check your spam folder and mark us as 'Not Spam'.
  </div>
</body>
</html>
