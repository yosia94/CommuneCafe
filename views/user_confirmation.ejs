<!DOCTYPE html>
<html>
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <link rel="icon" type="image/x-icon" href="/communefavicon.ico">
  <title>User Confirmation Registration - Commune Cafe</title>
  <link rel="stylesheet" href="/styles.css">
</head>
<body>
  <div class="form-box">
    <h2>User Confirmation Registration</h2>
    <form action="/admin/user-confirmation" method="post">
      <label>Instruction Text</label>
      <textarea 
        name="instruction"
        rows="6"
        placeholder="Enter instruction for user..."
      ><%= instruction %></textarea>
      <button type="submit">Save</button>
    </form>
    <a href="/admin/dashboard" class="back-button">⬅ Back to Dashboard</a>
    <a href="/" class="back-button">⬅ Back to Main Page</a>
  </div>
</body>
</html>